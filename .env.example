# Required for docker compose startup.
# Generate a long random token, for example:
#   openssl rand -hex 32
BOB_API_TOKEN=replace_with_long_random_secret

# Required when auth is enabled. Set to the exact origin that should call the API.
# Examples:
#   https://bob.example.com
#   http://localhost:5173
BOB_API_CORS_ORIGIN=https://bob.example.com
